{
  "manifest_version": 3,
  "name": "WebExplorer",
  "version": "0.1.2",
  "description": "View your browsing history as a tree, in the spirit of IBM WebExplorer.",
  "browser_specific_settings": {
    "gecko": {
      "id": "webexplorer@kaply.com",
      "update_url": "https://raw.githubusercontent.com/mkaply/webexplorer/main/updates.json",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["webNavigation", "storage", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Show history tree",
    "default_icon": {
      "32": "icons/webex.png",
      "96": "icons/webex.png"
    }
  },
  "sidebar_action": {
    "default_title": "WebExplorer",
    "default_panel": "tree.html",
    "default_icon": "icons/webex.png"
  },
  "icons": {
    "32": "icons/webex.png",
    "96": "icons/webex.png"
  }
}
